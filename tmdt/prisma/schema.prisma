datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------
// IDENTITY DOMAIN
// ----------------------------------------

model users {
  id             String    @id @default(uuid())
  email          String    @unique(map: "uq_users_email")
  password_hash  String
  role           String    // customer, admin, warehouse
  account_status String    // active, locked
  full_name      String    @default("")
  phone          String    @default("")
  created_at     DateTime  @default(now())
  updated_at     DateTime? @updatedAt

  addresses    user_addresses[]
  sessions     sessions[]
  carts        carts?
  orders       orders[]
  export_jobs  export_jobs[]
  audit_logs   audit_logs[]

  @@index([role], map: "idx_users_role")
  @@index([account_status], map: "idx_users_account_status")
  @@index([created_at], map: "idx_users_created_at")
}

model user_addresses {
  id           String   @id @default(uuid())
  user_id      String
  address_line String
  position     Int
  created_at   DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, position], map: "uq_user_addresses_user_position")
  @@unique([user_id, address_line], map: "uq_user_addresses_user_address")
  @@index([user_id], map: "idx_user_addresses_user_id")
}

model sessions {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String   @unique(map: "uq_sessions_token_hash")
  role       String
  expires_at DateTime
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_sessions_user_id")
  @@index([expires_at], map: "idx_sessions_expires_at")
}

// ----------------------------------------
// CATALOG DOMAIN
// ----------------------------------------

model products {
  id            String    @id
  slug          String    @unique(map: "uq_products_slug")
  name          String
  category      String
  description   String
  price_minor   Int
  thumbnail_url String?
  is_active     Boolean
  created_at    DateTime  @default(now())
  updated_at    DateTime? @updatedAt

  variants product_variants[]
  media    product_media[]

  @@index([category, is_active], map: "idx_products_category_is_active")
  @@index([is_active], map: "idx_products_is_active")
  @@index([created_at], map: "idx_products_created_at")
}

model product_variants {
  id           String    @id @default(uuid())
  product_id   String
  variant_code String    @unique(map: "uq_product_variants_variant_code")
  size         String
  color        String
  stock        Int
  is_active    Boolean
  created_at   DateTime  @default(now())
  updated_at   DateTime? @updatedAt

  product products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  cart_items          cart_items[]
  order_items         order_items[]
  inventory_movements inventory_movements[]

  @@unique([product_id, size, color], map: "uq_product_variants_product_size_color")
  @@index([product_id], map: "idx_product_variants_product_id")
  @@index([stock], map: "idx_product_variants_stock")
}

model product_media {
  id         String   @id @default(uuid())
  product_id String
  url        String
  position   Int
  created_at DateTime @default(now())

  product products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, position], map: "uq_product_media_product_position")
  @@index([product_id], map: "idx_product_media_product_id")
}

model inventory_movements {
  id                 String   @id @default(uuid())
  product_variant_id String
  movement_type      String
  quantity_delta     Int
  reason             String?
  reference_type     String?
  reference_id       String?
  created_at         DateTime @default(now())

  variant product_variants @relation(fields: [product_variant_id], references: [id])

  @@index([product_variant_id, created_at], map: "idx_inventory_movements_variant_created")
  @@index([reference_type, reference_id], map: "idx_inventory_movements_reference")
}

// ----------------------------------------
// CART DOMAIN
// ----------------------------------------

model carts {
  id         String    @id @default(uuid())
  user_id    String    @unique(map: "uq_carts_user_id")
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  items cart_items[]

  @@index([user_id], map: "idx_carts_user_id")
}

model cart_items {
  id                 String    @id @default(uuid())
  cart_id            String
  product_variant_id String
  quantity           Int
  added_at           DateTime  @default(now())
  updated_at         DateTime? @updatedAt

  cart    carts            @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  variant product_variants @relation(fields: [product_variant_id], references: [id], onDelete: Restrict)

  @@unique([cart_id, product_variant_id], map: "uq_cart_items_cart_variant")
  @@index([cart_id], map: "idx_cart_items_cart_id")
  @@index([product_variant_id], map: "idx_cart_items_variant_id")
}

// ----------------------------------------
// ORDER DOMAIN
// ----------------------------------------

model orders {
  id                       String    @id @default(uuid())
  user_id                  String
  status                   String
  selected_address         String
  selected_shipping_method String
  note                     String    @default("")
  subtotal_minor           Int
  shipping_fee_minor       Int
  discount_minor           Int
  total_minor              Int
  picked_at                DateTime?
  packed_at                DateTime?
  shipped_at               DateTime?
  delivered_at             DateTime?
  cancelled_at             DateTime?
  created_at               DateTime  @default(now())
  updated_at               DateTime? @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Restrict)

  items                order_items[]
  shipment             shipments?
  payment_transactions payment_transactions[]
  payment_callbacks    payment_callbacks[]
  audit_logs           audit_logs[]

  @@index([user_id, created_at(sort: Desc)], map: "idx_orders_user_id_created_at")
  @@index([status, updated_at(sort: Desc)], map: "idx_orders_status_updated_at")
  @@index([created_at], map: "idx_orders_created_at")
  @@index([selected_shipping_method], map: "idx_orders_selected_shipping_method")
}

model order_items {
  id                    String   @id @default(uuid())
  order_id              String
  product_variant_id    String
  product_slug_snapshot String
  title_snapshot        String
  price_minor_snapshot  Int
  quantity              Int
  created_at            DateTime @default(now())

  order   orders           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant product_variants @relation(fields: [product_variant_id], references: [id], onDelete: Restrict)

  @@unique([order_id, product_variant_id], map: "uq_order_items_order_variant")
  @@index([order_id], map: "idx_order_items_order_id")
}

// ----------------------------------------
// PAYMENT DOMAIN
// ----------------------------------------

model payment_transactions {
  id                      String    @id @default(uuid())
  order_id                String
  retry_of_transaction_id String?
  method                  String
  status                  String
  amount_minor            Int
  provider                String
  provider_reference      String?
  checkout_url            String?
  last_idempotency_key    String?
  callback_event_time     DateTime?
  callback_received_at    DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime? @updatedAt

  order                 orders                 @relation(fields: [order_id], references: [id], onDelete: Restrict)
  retry_of_transaction  payment_transactions?  @relation("RetryOfTransaction", fields: [retry_of_transaction_id], references: [id], onDelete: SetNull)
  retried_by_transaction payment_transactions[] @relation("RetryOfTransaction")

  callbacks payment_callbacks[]

  // SQLite doesn't support partial unique indexes directly via prisma unique definition,
  // but we can define the standard ones. 
  @@unique([provider, provider_reference], map: "uq_payment_transactions_provider_provider_reference")
  @@unique([provider, last_idempotency_key], map: "uq_payment_transactions_provider_last_idempotency_key")
  
  @@index([order_id, created_at(sort: Desc)], map: "idx_payment_transactions_order_created")
  @@index([status, updated_at(sort: Desc)], map: "idx_payment_transactions_status_updated")
  @@index([provider_reference], map: "idx_payment_transactions_provider_reference")
}

model payment_callbacks {
  id                     String    @id @default(uuid())
  payment_transaction_id String
  order_id               String
  idempotency_key        String
  provider_reference     String
  raw_status             String
  mapped_status          String
  event_time             DateTime?
  received_at            DateTime  @default(now())
  raw_payload            String    // Used String instead of Json for SQLite compatibility

  transaction payment_transactions @relation(fields: [payment_transaction_id], references: [id], onDelete: Cascade)
  order       orders               @relation(fields: [order_id], references: [id], onDelete: Restrict)

  @@unique([provider_reference, idempotency_key], map: "uq_payment_callbacks_provider_idempotency_key")
  @@index([payment_transaction_id, received_at(sort: Desc)], map: "idx_payment_callbacks_transaction_received")
  @@index([order_id, received_at(sort: Desc)], map: "idx_payment_callbacks_order_received")
  @@index([provider_reference], map: "idx_payment_callbacks_provider_reference")
}

// ----------------------------------------
// SHIPPING DOMAIN
// ----------------------------------------

model shipments {
  id              String    @id @default(uuid())
  order_id        String    @unique(map: "uq_shipments_order_id")
  tracking_number String    @unique(map: "uq_shipments_tracking_number")
  carrier         String?
  status          String
  last_synced_at  DateTime?
  is_degraded     Boolean   @default(false)
  degraded_reason String?
  retryable       Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime? @updatedAt

  order orders @relation(fields: [order_id], references: [id], onDelete: Cascade)

  events shipment_events[]

  @@index([status, updated_at(sort: Desc)], map: "idx_shipments_status_updated")
  @@index([tracking_number], map: "idx_shipments_tracking_number")
}

model shipment_events {
  id          String   @id @default(uuid())
  shipment_id String
  status      String
  event_time  DateTime
  source      String
  payload     String   // Used String instead of Json for SQLite compatibility
  created_at  DateTime @default(now())

  shipment shipments @relation(fields: [shipment_id], references: [id], onDelete: Cascade)

  @@index([shipment_id, event_time(sort: Desc)], map: "idx_shipment_events_shipment_event_time")
}

// ----------------------------------------
// AUDIT LOGS & REPORTING DOMAIN
// ----------------------------------------

model audit_logs {
  id             String   @id @default(uuid())
  actor_id       String?
  order_id       String?
  action         String
  before_status  String?
  after_status   String?
  reason         String?
  correlation_id String?
  metadata       String?  // Used String instead of Json for SQLite compatibility
  timestamp      DateTime @default(now())

  actor users?  @relation(fields: [actor_id], references: [id], onDelete: SetNull)
  order orders? @relation(fields: [order_id], references: [id], onDelete: SetNull)

  @@index([order_id, timestamp(sort: Desc)], map: "idx_audit_logs_order_timestamp")
  @@index([actor_id, timestamp(sort: Desc)], map: "idx_audit_logs_actor_timestamp")
  @@index([correlation_id], map: "idx_audit_logs_correlation_id")
  @@index([action, timestamp(sort: Desc)], map: "idx_audit_logs_action_timestamp")
}

model export_jobs {
  id           String    @id @default(uuid())
  user_id      String?
  report_type  String
  format       String
  status       String
  start_date   DateTime
  end_date     DateTime
  download_url String?
  created_at   DateTime  @default(now())
  updated_at   DateTime? @updatedAt

  user users? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at(sort: Desc)], map: "idx_export_jobs_user_id_created")
  @@index([status, created_at(sort: Desc)], map: "idx_export_jobs_status_created")
}
